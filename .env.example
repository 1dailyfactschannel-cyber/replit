# PostgreSQL Security Configuration
# Сохраните этот файл как .env в той же папке, что и stack файл

# PostgreSQL Settings
POSTGRES_DB=teamsync
POSTGRES_USER=teamsync_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_YOUR_SECURE_PASSWORD

# PgAdmin Settings  
PGADMIN_DEFAULT_EMAIL=admin@your-domain.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# Network Settings
POSTGRES_PORT=5432
PGADMIN_PORT=5050

# Yandex Calendar OAuth Configuration
# Get these from https://oauth.yandex.ru/
YANDEX_CLIENT_ID=your_yandex_client_id_here
YANDEX_CLIENT_SECRET=your_yandex_client_secret_here

# Application URL (for OAuth callback)
APP_URL=http://localhost:3000
# For production:
# APP_URL=https://your-domain.com