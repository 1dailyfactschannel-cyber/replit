# Portainer / Docker Deployment Configuration
# Сохраните этот файл как .env в той же папке, что и stack файл

# PostgreSQL (внешняя база данных)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB_NAME

# Сессия (обязательно установите секретный ключ!)
SESSION_SECRET=change_this_to_random_long_string

# CORS (обязательно для работы фронтенда)
# Используйте IP вашего сервера + порт фронтенда (8090)
ALLOWED_ORIGINS=http://your-server-ip:8090

# URL приложения
APP_URL=http://your-server-ip:8090

# Разрешить HTTP (для работы cookies без HTTPS)
ALLOW_HTTP=true

# Redis (опционально, для production рекомендуется)
REDIS_URL=

# Ключи Яндекс Календаря (если нужно)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
